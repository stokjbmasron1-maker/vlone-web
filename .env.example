# CodeX Cheats — Environment Variables
# Copy this to .env and fill in your Supabase credentials

VITE_SUPABASE_URL=your-project-url-here
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Vercel / serverless only (never commit real values; set in Vercel dashboard)
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=
# JWT_SECRET=
# Optional: rate limit for POST /api/verify (default 30 req per VERIFY_RATE_WINDOW_MS)
# VERIFY_RATE_MAX=30
# VERIFY_RATE_WINDOW_MS=60000
